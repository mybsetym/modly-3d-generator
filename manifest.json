{
  "id": "modly-3d-generator",
  "name": "TripoSR 3D Generator",
  "version": "1.0.0",
  "description": "Image to 3D GLB model generator using TripoSR",
  "author": "mybsetym",
  "nodes": [
    {
      "name": "Image to 3D",
      "type": "generator",
      "description": "Convert a 2D image to a 3D GLB model",
      "inputs": [
        {
          "name": "image",
          "type": "image",
          "description": "Source image"
        },
        {
          "name": "prompt",
          "type": "string",
          "description": "Optional prompt for segmentation",
          "default": ""
        }
      ],
      "outputs": [
        {
          "name": "model",
          "type": "mesh",
          "description": "Generated 3D model"
        }
      ],
      "generator": "generator.py"
    }
  ]
}
