{
  "id": "modly-3d-generator",
  "name": "TripoSR 3D Generator",
  "version": "1.0.0",
  "description": "Image to 3D GLB model generator using TripoSR",
  "author": "mybsetym",
  "type": "generator",
  "generator": "generator.py",
  "requirements": [
    "torch>=2.0.0",
    "torchvision",
    "diffusers",
    "transformers",
    "huggingface-hub",
    "pillow",
    "numpy",
    "trimesh",
    "pygltflib"
  ],
  "model": {
    "name": "TripoSR",
    "repo_id": "stabilityai/TripoSR",
    "filename": "model.fp16.safetensors"
  },
  "inputs": {
    "image": {
      "type": "image",
      "description": "Source image for 3D generation"
    },
    "prompt": {
      "type": "string",
      "description": "Optional description for better segmentation"
    }
  },
  "outputs": {
    "model": {
      "type": "glb",
      "description": "Generated 3D model"
    }
  }
}
